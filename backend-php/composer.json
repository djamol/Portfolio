{
  "name": "portfolio/backend-php",
  "description": "Portfolio Financial Management Backend (PHP)",
  "type": "project",
  "license": "ISC",
  "require": {
    "php": ">=8.1",
    "slim/slim": "^4.12",
    "slim/psr7": "^1.6",
    "vlucas/phpdotenv": "^5.6",
    "mongodb/mongodb": "^1.19"
  },
  "autoload": {
    "files": [
      "utils/logger.php",
      "utils/snapshot-queries.php",
